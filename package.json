{
    "name": "@r47onfire/backolon",
    "version": "0.0.0",
    "private": true,
    "description": "",
    "keywords": [],
    "author": "dragoncoder047",
    "main": "src/index.ts",
    "scripts": {
        "build": "pnpm esbuild --bundle --sourcemap --platform=browser --target=esnext --format=esm src/index.ts --outfile=dist/backolon.js",
        "build-for-fuzzer": "pnpm esbuild --bundle --sourcemap --platform=node --target=esnext --format=cjs src/index.ts --outfile=dist/backolon.cjs",
        "build:website": "pnpm run \"/^build:website:.*/\"",
        "build:website:js": "rm -rf docs/js && pnpm bun run build-website.js",
        "build:website:typedoc": "pnpm typedoc",
        "dev": "pnpm run \"/^dev:.*/\"",
        "dev:serve": "python3 -m http.server -d docs",
        "dev:watch": "pnpm nodemon -e js,ts,tsx -i docs -w src -w website --exec \"pnpm build:website\"",
        "fuzz": "pnpm build-for-fuzzer; ./fuzz.sh",
        "test": "pnpm bun test",
        "test:watch": "pnpm test --watch",
        "prepare": "pnpm build --minify"
    },
    "license": "GPL-3.0-only",
    "repository": {
        "type": "git",
        "url": "https://github.com/r47onfire/backolon.git"
    },
    "devDependencies": {
        "@gitlab-org/jsfuzz": "^1.2.4",
        "@to-skills/typedoc": "^0.5.1",
        "@types/bun": "^1.3.9",
        "@types/jquery": "^4.0.0",
        "bun": "^1.3.9",
        "esbuild": "^0.25.0",
        "jquery": "^4.0.0",
        "jquery.terminal": "^2.45.2",
        "nodemon": "^3.1.14",
        "prismjs": "^1.30.0",
        "typedoc": "^0.28.18",
        "typescript": "^5.6.2",
        "vanilla": "github:dragoncoder047/vanilla"
    },
    "type": "module",
    "pnpm": {
        "onlyBuiltDependencies": [
            "bun",
            "esbuild"
        ]
    },
    "dependencies": {
        "lib0": "^0.2.117",
        "resurrect-esm": "^2.0.5"
    }
}