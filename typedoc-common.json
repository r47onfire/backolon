{
    "$schema": "https://typedoc.org/schema.json",
    "entryPointStrategy": "expand",
    "tsconfig": "./tsconfig.json",
    "exclude": [
        "./test/**/*",
        "./node_modules/**/*"
    ],
    "excludePrivate": true,
    "excludeExternals": true,
    "hideGenerator": true,
    "includeVersion": true,
    "disableSources": false,
    "skipErrorChecking": true,
    "disableGit": true,
    "sourceLinkTemplate": "https://github.com/r47onfire/backolon/blob/main/{path}#L{line}",
    "favicon": "./docs/images/icon.png",
    "useTsLinkResolution": true,
    "preservedTypeAnnotationTags": [
        "@param",
        "@returns",
        "@type",
    ],
    "ignoredHighlightLanguages": [
        "backolon"
    ],
    "intentionallyNotExported": [
        "MapValues",
        "Hashed",
        "ChildrenType",
        "ValueType",
        "TOKENIZE_RULES",
        "OneTypeThing",
    ]
}